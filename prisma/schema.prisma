generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {

  id          String   @id @default(cuid())
  fullName    String
  email       String
  phone       String?
  company     String?
  services    Json?
  budget      String?
  timeline    String?
  message     String
  source      String   @default("Website")
  status      LeadStatus @default(NEW)
  isRead      Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  IN_PROGRESS
  COMPLETED
  CLOSED
}
